change_window_state() {
	local windowid=$1
	local prop=$2
	local action=${3:-$X_NET_WM_STATE_TOGGLE}
	local is_present if_present if_absent

	local -n window="window_$windowid"
	local state=${window[state]}

	case $action in
		$X_NET_WM_STATE_REMOVE ) if_present=1  ;;
		$X_NET_WM_STATE_ADD )    if_absent=1   ;;
		$X_NET_WM_STATE_TOGGLE ) if_present=1; if_absent=1 ;;
		* ) fail "Invalid change_window_state action %s\n" $action
	esac
	
	[[ $state =~ " $prop " ]] && is_present=1
	(( if_present && is_present )) && state="${state/ $prop/}"
	(( if_absent && ! is_present )) && state+=" $prop "
	
	window[state]=$state
}

update_window_state() {
	local windowid=$1
	local action=$2
	local props=( $3 $4 )
	local prop

	for prop in ${props[@]}; do
		(( prop == X_NET_WM_STATE_FULLSCREEN )) || continue
		change_window_state $windowid $prop $action
	done
}

update_fullscreen() {
	local windowid=$1
	local is_fullscreen
	local want_fullscreen=0
	local fs_prop=$X_NET_WM_STATE_FULLSCREEN
	local -n window="window_$windowid"

	is_fullscreen=$(( ${window[fullscreen]} ))
	[[ ${window[state]} =~ " $fs_prop " ]] && want_fullscreen=1

	if (( ! is_fullscreen && want_fullscreen )); then
		send_set_window_pos $windowid \
			0 0 \
			${screen_0[width_pixels]} ${screen_0[height_pixels]} \
			0 $X_Above
		window[fullscreen]=1
	elif (( is_fullscreen && ! want_fullscreen )); then
		send_set_window_pos $windowid
		window[fullscreen]=0
	fi
}

handle_client_message() {
	local format windowid atom i num_values
	local values=()

	read8 format
	readpad 2
	read32 windowid
	read32 atom

	num_values=$(( 160 / format ))
	for (( i=0 ; i<num_values ; i++ )); do
		read$format value
		values[i]=$value
	done
	log '< ClientMessage %s %s %s [0]=%s [1]=%s ...\n' \
			$format $windowid $atom ${values[0]} ${values[1]}
	case $atom in
	$XA_NET_CURRENT_DESKTOP) 
		select_desktop ${values[0]} 
		;;
	$XA_NET_STATE) 
		update_window_state $windowid \
			${values[0]} ${values[1]} ${values[2]}
		update_fullscreen $windowid
		;;
	esac
}

intern_atoms() {
	send_intern_atom UTF8_STRING
	send_intern_atom _NET_CURRENT_DESKTOP
	send_intern_atom _NET_NUMBER_OF_DESKTOPS
	send_intern_atom _NET_DESKTOP_VIEWPORT
	send_intern_atom _NET_WORKAREA
	send_intern_atom _NET_SUPPORTED
	send_intern_atom _NET_ACTIVE_WINDOW
	send_intern_atom _NET_SUPPORTING_WM_CHECK
	send_intern_atom _NET_WM_NAME
	send_intern_atom _NET_WM_STATE
	send_intern_atom _NET_WM_STATE_FULLSCREEN
	send_intern_atom _NET_WM_WINDOW_TYPE
	send_intern_atom _NET_WM_WINDOW_TYPE_NORMAL
	send_intern_atom _NET_WM_STRUT_PARTIAL
	send_intern_atom _NET_CLIENT_LIST
}

select_desktop() {
	local desktop=$1
	local root=${screen_0[root]}

	[[ $current_desktop != $desktop ]] || return

	send_change_property $root $X_PropModeReplace \
		$XA_NET_CURRENT_DESKTOP $XA_CARDINAL 32 1 $desktop
	
	hide_desktop $current_desktop
	current_desktop=$desktop
	show_desktop $current_desktop
}

