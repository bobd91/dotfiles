select_desktop() {
	local desktop=$1

	[[ $current_desktop != $desktop ]] || return

	send_change_property $root $XA_NET_CURRENT_DESKTOP \
		$XA_CARDINAL 32 1 $desktop
	
	hide_desktop $current_desktop
	current_desktop=$desktop
	show_desktop $current_desktop
}

