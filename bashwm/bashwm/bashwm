handle_configure_request() {
	local stack_mode parent window windowid sibling 
	local x y width height border_width value_mask n

	read8 stack_mode
	readpad 2
	read32 parent
	read32 windowid
	read32 sibling
	read16 x
	read16 y
	read16 width
	read16 height
	read16 border_width
	read16 value_mask
	readpad 4

	log '> ConfigureWindow %s\n' $windowid

	local -n window="window_$windowid"

	n=$(count_bits $value_mask)
	beginrequest $X_ConfigureWindow 0 $(( 3+n ))
	write32 $windowid
	write16 $value_mask
	writepad 2
	(( $value_mask & $X_CWX )) && 
		write32 $x && 
		window[x]=$x
	(( $value_mask & $X_CWY )) && 
		write32 $y && 
		window[y]=$y
	(( $value_mask & $X_CWWidth )) && 
		write32 $width &&
		window[width]=$width
	(( $value_mask & $X_CWHeight )) &&
		write32 $height &&
		window[height]=$height
	(( $value_mask & $X_CWBorderWidth )) &&
		write32 $border_width &&
		window[border_width]=$border_width
	(( $value_mask & $X_CWSibling )) && 
		write32 $sibling
	(( $value_mask & $X_CWStackMode )) && 
		write32 $stack_mode
}

