run() {
	readxauth < "${XAUTHORITY:-~/.Xauthority}"

	exec {xfd}<>/dev/tcp/127.0.0.1/$(( 6000+$dsp ))

	send_setup >&${xfd}
	read_setup_leader <&${xfd}

	if (( $setup_success != 1 )); then
		read_setup_failure <&${xfd}

		printf 'Setup Failed '
		(( $setup_success == 2 )) && printf '(Auth) '
		printf ': %s\n' "$setup_failure_reason"
		exit $setup_success
	fi

	read_setup_ok <&${xfd}

	local root=${screen_0[root]}

	intern_atoms >&${xfd}
	send_get_keyboard_mapping >&${xfd}
	send_change_window_events $root $root_events >&${xfd}
	add_wmcheck_window >&${xfd}

	send_query_tree $root read_adopt_windows >&${xfd}

	$autostart

	event_loop >&${xfd} <&${xfd}

	if (( $error_code )); then
		printf 'Error code: %d\n' $error_code
		printf 'Error seq_no: %d\n' $error_seq_no
		printf 'Error data: %04x\n' $error_data
		printf 'Error op code: %d:%d\n' $error_major_op_code $error_minor_op_code
	fi
}

