handle_key_press() {
	local keycode keymask keycode_cmd keycmd mask cmd

	read8 keycode
	readpad 26
	read16 keymask
	readpad 2

	keycode_cmd="${keycode_command_map[keycode]}" 
	[[ $keycode_cmd ]] || return 0

	IFS=',' read -ra keycmds <<< "$keycode_cmd"
	for keycmd in "${keycmds[@]}"; do
		mask="${keycmd%:*}"
		(( mask == keymask )) || continue
		cmd="${keycmd#*:}"
		$cmd
		break
	done
}
event_handlers[X_KeyPress]=handle_key_press

add_window() {
	local x=0
	local y=0
	local width=$width_pixels
	local height=$height_pixels

	echo $x $y $width $height
}

after_reply() {
	local cmd="(${@@Q})"
	local len=${#cmd}
	

	after_replies[sequence_number]+="${len}${cmd}"
}


handle_map_request() {
	local window

	readpad 7
	read32 window
	readpad 20

	log 'MapRequest for window %s\n' $window

	if [[ ! -v "window_$window"[$XA_NET_WM_WINDOW_TYPE] ]]; then
		send_get_property $window $XA_NET_WM_WINDOW_TYPE $XA_ATOM 1
		send_get_property $window $XA_NET_WM_STRUT_PARTIAL $XA_CARDINAL 12
		send_get_property $window $XA_WM_TRANSIENT_FOR $XA_WINDOW 1
		send_get_property $window $XA_WM_NORMAL_HINTS $XA_WM_SIZE_HINTS 18
		send_get_property $window $XA_WM_HINTS $XA_WM_HINTS 9
		after_reply map_window $window
		send_change_window_events $window $client_events
	else
		map_window $window
	fi
}
event_handlers[X_MapRequest]=handle_map_request

map_window() {
	local window=$1
	pos=( $(add_window) )
	send_set_border_color $window $(( 16#005577 )) # $focus_border
	send_set_window_pos $window ${pos[@]} 2 #$border_width
	send_map_window $window
}

handle_unmap_notify() {
	local window

	readpad 7
	read32 window
	readpad 20

	log 'UnmapNotify for window %s\n' $window

	remove_window $window
}


