#!/usr/bin/env bash

log() {
	local c1=${1::1}
	[[ $c1 == '<' || $c1 == '>' ]] && printf '\n' >> bashwm.log
	printf "$@" >> bashwm.log
}

write8() {
	local t=00
	(( $1 )) && printf -v t '%02x' "$(( $1 & 16#FF ))"
	printf '%b' "\x$t"

	log ' %s' $t
}

write16() {
	local val=$1

	write8 $(( val >> 8 ))
	write8 $val
}

write32() {
	local val=$1

	write8 $(( val >> 24 ))
	write8 $(( val >> 16 ))
	write8 $(( val >> 8 ))
	write8 $val
}

writepad() {
	local i
	for (( i=0 ; i<$1 ; i++ )); do
		write8 0
	done
}

pad4() {
	local l=$1
	echo $(( (4 - (l % 4)) % 4 ))
}

writepad4() {
	writepad $(pad4 $1)
}


writechars() {
	local len=$1
	local chars=$2
	printf '%s' "$2"

	log '%s' "$2"
}

writebytes() {
	local len=$1
	local bytes=$2
	local byte_count=$(( ${#bytes}/2 ))
	local i b

	for (( i=0 ; i<byte_count ; i++ )); do
		b=$(( i*2 ))
		printf '%b' "\x${bytes:b:2}"

		log ' %s' "${bytes:b:2}"
	done
	# If len > byte_count pad with nulls
	for (( i=byte_count ; i<len ; i++ )); do
		printf '%b' '\x00'

		log ' 00'
	done
}

read8() {
	local _t

	IFS= read -r -d '' -n 1 _t
	if [[ -n $_t ]]; then
		printf -v "$1" '%d' "'$_t"
	else
		printf -v "$1" "0"
	fi

	log ' %02x' "'$_t"
}

read16() {
	local _b1 _b2
	read8 _b1
	read8 _b2
	printf -v "$1" "$(( _b2 + (_b1 << 8) ))"
}

read32() {
	local _b1 _b2 _b3 _b4
	read8 _b1
	read8 _b2
	read8 _b3
	read8 _b4
	printf -v "$1" "$(( _b4 + (_b3 << 8) + (_b2 << 16) + (_b1 << 24) ))"
}

readchars() {
	local _i _c _s

	(( $1 )) || return

	for (( _i=0 ; _i<$1 ; _i++ )); do
		IFS= read -r -d '' -n 1 _c
		if [[ -z $_c ]]; then
			readpad $(( $1 - _i - 1 ))
			break
		fi
		_s="$_s$_c"
	done
	printf -v "$2" '%s' "$_s"

	log ' %s' "$_s"
}

readbytes() {
	local _i _c _b _s

	(( $1 )) || return

	for (( _i=0 ; _i<$1 ; _i++ )); do
		IFS= read -r -d '' -n 1 _c
		if [[ -z $_c ]]; then
			_b='00'
		else
			printf -v _b '%d' "'$_c"
			printf -v _b '%02x' $_b
		fi
		_s+=$_b
	done

	printf -v "$2" $_s

	log ' %s' "$_s"
}

readpad() {
	local pad i

	for (( i=0 ; i<$1 ; i++ )); do
		IFS= read -r -d '' -n 1 pad

		log ' 00'
	done
}

readpad4() {
	readpad $(pad4 $1)
}

readxauth() {
	local proto=256
	local addr="${HOSTNAME}"
	local display="${dsp#*:}"
	local length=1

	while [[ $length != 0 && ($xauth_proto != $proto ||
				  $xauth_addr != $addr ||
				  $xauth_display != $display) ]]; do
		read16 xauth_proto
		read16 length
		readchars $length xauth_addr
		read16 length
		readchars $length xauth_display
		read16 xauth_name_length 
		readchars $xauth_name_length xauth_name
		read16 xauth_data_length
		readbytes $xauth_data_length xauth_data
	done
}

send_setup() {
	local lsb_first="$(( 16#42 ))"
	local name_len=${#xauth_name}
	local data_len=${#xauth_data}

	log '> Setup Request\n'

	write8 $lsb_first
	writepad 1
	write16 $proto_major
	write16 $proto_minor
	write16 $name_len
	write16 $data_len
	writepad 2
	writechars $name_len "$xauth_name"
	writepad4 $name_len
	writebytes $data_len "$xauth_data"
	writepad4 $data_len
}

read_setup_leader() {
	log '< Setup Leader\n'

	read8 setup_success
	read8 setup_length
	read16 proto_major
	read16 proto_minor
	read16 extra_length
}

read_setup_failure() {
	log '< Setup Failure\n'

	readchars $setup_length setup_failure_reason
	readpad "$(( extra_length * 4 - setup_length ))"
}

read_setup_ok() {
	local release_number resource_id_base resource_id_mask 
	local motion_buffer_size vendor_length max_request_length
	local no_of_screens no_of_formats image_byte_order bitmap_byte_order
	local bitmap_scanline_unit bitmap_scanline_pad min_keycode max_keycode
	local vendor i root colormap white_pixel black_pixel input_masks
	local width_pixels height_pixels width_mm height_mm min_maps max_maps
	local visual_id backing_stores save_unders root_depth no_of_depths
	local d depth no_of_visuals v class bits_per_rgb colormaps
	local red_mask green_mask blue_mask

	log '< Setup OK\n'

	read32 release_number
	read32 resource_id_base
	read32 resource_id_mask
	read32 motion_buffer_size
	read16 vendor_length
	read16 max_request_length
	read8 no_of_screens
	read8 no_of_formats
	read8 image_byte_order
	read8 bitmap_byte_order
	read8 bitmap_scanline_unit
	read8 bitmap_scanline_pad
	read8 min_keycode
	read8 max_keycode
	readpad 4
	readchars $vendor_length vendor 
	readpad4 $vendor_length
	readpad $(( 8 * no_of_formats ))

	declare -Ag "server=(\
		resource_id_base $resource_id_base \
		resource_id_mask $resource_id_mask \
		no_of_screens $no_of_screens \
		min_keycode $min_keycode \
		max_keycode $max_keycode)"

	for (( i=0 ; i<no_of_screens ; i++ )); do
		read32 root
		read32 colormap
		read32 white_pixel
		read32 black_pixel
		read32 input_masks
		read16 width_pixels
		read16 height_pixels
		read16 width_mm
		read16 height_mm
		read16 min_maps
		read16 max_maps
		read32 visual_id
		read8 backing_stores
		read8 save_unders
		read8 root_depth
		read8 no_of_depths

		declare -Ag "screen_$i=( \
			root $root \
			width_pixels $width_pixels \
			height_pixels $height_pixels)"

		for (( d=0 ; d<no_of_depths ; d++ )); do
			read8 depth
			readpad 1
			read16 no_of_visuals
			readpad 4
			for (( v=0 ; v<no_of_visuals ; v++ )); do
				read32 visual_id
				read8 class
				read8 bits_per_rgb
				read16 colormaps
				read32 red_mask
				read32 green_mask
				read32 blue_mask
				readpad 4
			done
		done
	done
}

beginrequest() {
	local opcode=$1
	local byte1=$2
	local req_length=$3
	local handler=${4:-${reply_handlers[$1]}}

	(( sequence_number++ ))
	write8 $opcode
	write8 $byte1
	write16 $req_length
	[[ $handler ]] && request_map[sequence_number & 16#FFFF]=$handler 

	log '> Request %s %s (%s)\n' $opcode $req_length $sequence_number
}

send_change_window_events() {
	local windowid=$1
	local mask=$2

	log '> Change Window Events %s\n' $windowid

	beginrequest $X_ChangeWindowAttributes 0 4
	write32 $windowid
	write32 $X_CWEventMask
	write32 $mask
}

send_get_keyboard_mapping() {
	local min_keycode=${server[min_keycode]}
	local max_keycode=${server[max_keycode]}

	log '> GetKeyboardMapping\n'

	beginrequest $X_GetKeyboardMapping 0 2
	write8 $min_keycode
	write8 $(( 1 + max_keycode - min_keycode ))
	writepad 2
}

send_grab_key() {
	local keycode=$1
	local mask=$2

	log '> GrabKey %s %s\n' $mask $keycode

	beginrequest $X_GrabKey 0 4
	write32 ${screen_0[root]}
	write16 $mask
	write8 $keycode
	write8 1
	write8 1
	writepad 3
}

send_set_border_color() {
	local windowid=$1
	local border_pixel=$2

	log '> SetBorderColor %s\n' $windowid

	beginrequest $X_ChangeWindowAttributes 0 4 
	write32 $windowid
	write32 $X_CWBorderPixel
	write32 $border_pixel
}

send_set_window_pos() {
	local windowid=$1
	local -n window="window_$windowid"
	local x=${2:-${window[old_x]}}
	local y=${3:-${window[old_y]}}
	local width=${4:-${window[old_width]}}
	local height=${5:-${window[old_height]}}
	local border_width=${6:-$wm_border_width}
	local stacking_order=$7

	log '> SetWindowPos %s\n' $windowid

	window[old_x]=${window[x]}
	window[old_y]=${window[y]}
	window[old_width]=${window[width]}
	window[old_height]=${window[height]}
	window[x]=x
	window[y]=y
	window[width]=width
	window[height]=height
	window[border_width]=$border_width

	mask=$(( X_CWX | X_CWY | X_CWWidth | X_CWHeight | X_CWBorderWidth ))
	(( $stacking_order )) && (( mask |= X_CWStackMode ))
	beginrequest $X_ConfigureWindow 0 8
	write32 $windowid
	write16 $mask
	writepad 2
	write32 $(( x - border_width ))
	write32 $(( y - border_width ))
	write32 $(( width - (2 * border_width) ))
	write32 $(( height - (2 * border_width) ))
	write32 $border_width
	(( $stacking_order )) && write32 $stacking_order
}

send_map_window() {
	local windowid=$1

	log '> MapWindow %s\n' $windowid

	beginrequest $X_MapWindow 0 2
	write32 $windowid
}

send_intern_atom() {
	local name=$1
	local name_len=${#name}
	local name_pad=$(pad4 name_len)
	local req_len=$(( 2 + (name_len + name_pad) / 4 ))
	
	log '> InternAtom %s\n' $name

	beginrequest $X_InternAtom 0 $req_len "read_intern_atom $name"
	write16 $name_len
	writepad 2
	writechars $name_len $name
	writepad $name_pad
}

read_keyboard_mapping() {
	local keysyms_per=$1
	local min_keycode=${server[min_keycode]}
	local max_keycode=${server[max_keycode]}
	local keycodes=$(( 1 + max_keycode - min_keycode ))
	local key_mappings=$(( keysyms_per * keycodes ))
	local keycode keycodesym keycmds keycmda keycmd mask

	log '< Keyboard Mapping\n'

	read32 reply_length
	(( reply_length == key_mappings )) ||
		die "Unexpected number of keboard mappings: " \
			"Got $reply_length, Expected $key_mappings"
	readpad 24

	for (( keycode=min_keycode ; keycode<=max_keycode ; keycode++ )); do
		# only interested in the first keysym
		read32 keycodesym
		readpad $(( 4 * (keysyms_per - 1) ))

		keycmds="${keysym_command_map[keycodesym]}"
		[[ $keycmds ]] || continue
		keycode_command_map[keycode]=$keycmds
	done

	for keycode in ${!keycode_command_map[@]}; do
		IFS=',' read -ra keycmds <<< "${keycode_command_map[keycode]}" 
		for keycmd in "${keycmds[@]}"; do
			mask="${keycmd%:*}"
			send_grab_key $keycode $mask
		done
	done
}

read_intern_atom() {
	local name=$1
	local root=${screen_0[root]}

	readpad 4
	read32 atom
	readpad 20

	log '< Atom %s = %d\n' $name $atom

	[[ ${name::1} == '_' ]] || name="_$name"

	printf -v "XA$name" $atom

	case $name in
		_NET_CURRENT_DESKTOP) 
			send_change_property $root $X_PropModeReplace $atom $XA_CARDINAL 32 1 $current_desktop 
			;;
		_NET_NUMBER_OF_DESKTOPS) 
			send_change_property $root $X_PropModeReplace $atom $XA_CARDINAL 32 1 $desktop_count
			;;
		_NET_DESKTOP_VIEWPORT)
			send_change_property $root $X_PropModeReplace $atom $XA_CARDINAL 32 2 0 0
	esac
}

send_change_property() {
	local windowid=$1
	local mode=$2
	local prop_atom=$3
	local prop_type=$4
	local prop_bits=$5
	local prop_count=$6
	local bytes=$(( prop_count * prop_bits / 8 ))
	local pad=$(pad4 $bytes)
	local req_len=$(( 6 + (bytes + pad) / 4 ))

	shift 6
	local prop_value=( $@ )

	log '> Change Property %s for window %s\n' $prop_atom $windowid

	beginrequest $X_ChangeProperty $mode $req_len
	write32 $windowid
	write32 $prop_atom
	write32 $prop_type
	write8 $prop_bits
	writepad 3
	write32 $prop_count

	if (( prop_type == XA_UTF8_STRING )); then
		writechars $prop_count $prop_value
	else
		for (( i=0 ; i<$prop_count ; i++ )); do
			write$prop_bits ${prop_value[i]}
		done
	fi
	writepad $pad
}

send_get_property() {
	local windowid=$1
	local atom=$2
	local atom_type=$3
	local length=$4
	local start=${5:-0}

	log '> Get property %d for window %d\n' $atom $windowid
	beginrequest $X_GetProperty 0 6 "read_get_property $windowid $atom $start"
	write32 $windowid
	write32 $atom
	write32 $atom_type
	write32 $start
	write32 $length
}


read_get_property() {
	local windowid=$1
	local atom=$2
	local start=$3
	local format=$4
	local reply_len atom_type length bytes_after
	local item val byte_count

	read32 reply_len
	read32 atom_type
	read32 bytes_after
	read32 length
	readpad 12

	log '< Property %d for window %d, length %d\n' $atom $windowid $length

	(( $length  )) || return

	local -n window="window_$windowid"

	if (( $start )); then
		val=" ${window[$atom]}"
	fi

	if [[ $atom_type == $WA_STRING ]]; then
		readchars $length item
		val+="$item"
	else
		for (( i=0 ; i < length ; i++ )); do
			read${format} item
			val+=" $item"
		done
		val=${val:1}
	fi
	byte_count=$(( length * format / 8 ))
	readpad4 $byte_count

	window[$atom]="$val"

	(( bytes_after )) || return
	
	(( start += byte_count ))
	(( bytes_after -= byte_count ))

	send_get_property $windowid $atom $atom_type $bytes_after $start
}

send_delete_property() {
	local windowid=$1
	local atom=$2

	log '> Delete property %s for window %s\n' $atom $windowid

	beginrequest $X_DeleteProperty 0 3
	write32 $windowid
	write32 $atom
}

allocate_id() {
	if (( last_id )); then
		(( last_id++ ))
	else
		last_id=1
		while (( ! last_id & ${server[resource_id_mask]} )); do
			(( last_id <<= 1))
		done
	fi

	echo $(( ${server[resource_id_base]} | last_id ))
}

add_check_window() {
	check_windowid=$(allocate_id)
	log '> Check window id=%s\n' $check_windowid

	beginrequest $X_CreateWindow 0 8
	write32 $check_windowid
	write32 ${screen_0[root]}
	write16 0
	write16 0
	write16 1
	write16 1
	write16 0
	write16 $X_InputOnly
	write32 $X_CopyFromParent
	write32 0
}

set_check_window_props() {
	local supported
	local root=${screen_0[root]}

	send_change_property $check_windowid $X_PropModeReplace \
		$XA_NET_SUPPORTING_WM_CHECK $XA_WINDOW 32 1 $check_windowid
	send_change_property $check_windowid $X_PropModeReplace \
		$XA_NET_WM_NAME $XA_UTF8_STRING 8 6 'bashwm'
	send_change_property $root $X_PropModeReplace \
		$XA_NET_SUPPORTING_WM_CHECK $XA_WINDOW 32 1 $check_windowid
	send_delete_property $root $XA_NET_CLIENT_LIST

	supported=( $XA_NET_CURRENT_DESKTOP $XA_NET_NUMBER_OF_DESKTOPS \
		$XA_NET_ACTIVE_WINDOW $XA_NET_SUPPORTED $XA_NET_WM_NAME \
		$XA_NET_WM_STATE $XA_NET_SUPPORTING_WM_CHECK \
		$XA_NET_WM_STATE_FULLSCREEN $XA_NET_WM_WINDOW_TYPE \
		$XA_NET_WM_WINDOW_TYPE_DOCK $XA_NET_WM_WINDOW_TYPE_NORMAL \
		$XA_NET_CLIENT_LIST )

	send_change_property $root $X_PropModeReplace $XA_NET_SUPPORTED \
		$XA_ATOM 32 ${#supported[@]} ${supported[@]}
}

event_loop() {
	local input_type=1
	while (( input_type != X_Error )); do
		read8 input_type

		handler=${event_handlers[input_type & 16#7F]}
		if [[ $handler ]]; then
			log '< %s\n' $handler
			$handler $input_type
		else
			log '< No handler for InputType %s\n' $input_type
			# discard unwanted event data
			readpad 31
		fi

	done
}

handle_error() {
	read8 error_code
	read16 error_seq_no
	read32 error_data
	read16 error_major_op_code
	read8 error_minor_op_code
	readpad 21
}

handle_reply() {
	read8 reply_byte
	read16 reply_seq_no
	handler=${request_map[reply_seq_no]}
	[[ $handler ]] || die "Unexpected reply: sequence number = $reply_seq_no"
	unset request_map[reply_seq_no]
	log '< Reply %s (%s)\n' "$handler" "$reply_seq_no" 
	$handler $reply_byte $reply_seq_no

	handle_after_reply $reply_seq_no
}

handle_after_reply() {
	local seq_no=$1
	local actions len lenlen action cmd
	if [[ -v after_replies[seq_no] ]]; then
		actions="${after_replies[seq_no]}"
		while (( ${#actions} )); do
			len="${actions%%(*}"
			lenlen=${#len}
			action="${actions:$lenlen:$len}"
			actions="${actions:(( lenlen + len ))}"
			declare -a cmd="$action"
			"${cmd[@]}"
		done
		unset after_replies[seq_no]
	fi
}

count_bits() {
	local mask=$1
	local count=0
	while (( mask )); do
		(( count+=mask&1, mask>>=1 ))
	done
	echo $count
}

handle_configure_notify() {
	local windowid
	readpad 7
	read32 windowid
	readpad 20

	log '< ConfigureNotify for window %s\n' $windowid
}

handle_create_notify() {
	local windowid x y width height border_width override_redirect
	readpad 7
	read32 windowid
	read16 x
	read16 y
	read16 width
	read16 height
	read16 border_width
	read8 override_redirect
	readpad 9

	log '< CreateNotify for window %s, override_redirect %s\n' $windowid $override_redirect

	(( override_redirect )) && return

	local index=${#windows[@]}
	windows+=( $windowid )

	declare -Ag "window_$windowid=( \
		index $index \
		x $x \
		y $y \
		width $width \
		height $height \
		border_width $border_width)"
	
	[[ $windowid == $check_windowid ]] && set_check_window_props
}

handle_map_notify() {
	local windowid override_redirect
	readpad 7
	read32 windowid
	read8 override_redirect
	readpad 19

	log '< MapNotify for window %s, override_redirect %s\n' $windowid $override_redirect
}

handle_configure_request() {
	local stack_mode parent window windowid sibling 
	local x y width height border_width value_mask n

	read8 stack_mode
	readpad 2
	read32 parent
	read32 windowid
	read32 sibling
	read16 x
	read16 y
	read16 width
	read16 height
	read16 border_width
	read16 value_mask
	readpad 4

	log '> ConfigureWindow %s\n' $windowid

	local -n window="window_$windowid"

	n=$(count_bits $value_mask)
	beginrequest $X_ConfigureWindow 0 $(( 3+n ))
	write32 $windowid
	write16 $value_mask
	writepad 2
	(( $value_mask & $X_CWX )) && 
		write32 $x && 
		window[x]=$x
	(( $value_mask & $X_CWY )) && 
		write32 $y && 
		window[y]=$y
	(( $value_mask & $X_CWWidth )) && 
		write32 $width &&
		window[width]=$width
	(( $value_mask & $X_CWHeight )) &&
		write32 $height &&
		window[height]=$height
	(( $value_mask & $X_CWBorderWidth )) &&
		write32 $border_width &&
		window[border_width]=$border_width
	(( $value_mask & $X_CWSibling )) && 
		write32 $sibling
	(( $value_mask & $X_CWStackMode )) && 
		write32 $stack_mode
}

handle_property_notify() {
	local windowid atom state

	readpad 3
	read32 windowid
	read32 atom
	readpad 4
	read8 state
	readpad 15

	log '< PropertyNotify for window %s, atom %s, state %s\n' \
		$windowid $atom $state
}

handle_motion_notify() {
	# ignore for now
	readpad 31
	log "< handle_motion_notify"
}

handle_enter_notify() {
	# ignore for now
	readpad 31
	log '< handle_enter_notify\n'
}

handle_destroy_notify() {
	# ignore for now
	readpad 31
	log '< handle_destroy_notify\n'
}

handle_button_press() {
	# ignore for now
	readpad 31
	log '< handle_button_press\n'
}

handle_button_release() {
	# ignore for now
	readpad 31
	log '< handle_button_release\n'
}

handle_key_press() {
	local keycode keymask keycode_cmd keycmd mask cmd

	read8 keycode
	readpad 26
	read16 keymask
	readpad 2

	log '< Key press %s\n' $keycode

	keycode_cmd="${keycode_command_map[keycode]}" 
	[[ $keycode_cmd ]] || return 0

	IFS=',' read -ra keycmds <<< "$keycode_cmd"
	for keycmd in "${keycmds[@]}"; do
		mask="${keycmd%:*}"
		(( mask == keymask )) || continue
		cmd="${keycmd#*:}"
		$cmd
		break
	done
}

add_window() {
	echo ${screen_0[wa_x]} ${screen_0[wa_y]} \
		${screen_0[wa_width} ${screen_0[wa_height]}
}

after_reply() {
	local cmd="(${@@Q})"
	local len=${#cmd}
	

	after_replies[sequence_number]+="${len}${cmd}"
}


handle_map_request() {
	local windowid

	readpad 7
	read32 windowid
	readpad 20

	log '< MapRequest for window %s\n' $windowid

	if [[ ! -v "window_$windowid"[XA_NET_WM_WINDOW_TYPE] ]]; then
		send_get_property $windowid $XA_NET_WM_WINDOW_TYPE $XA_ATOM 1
		send_get_property $windowid $XA_NET_WM_STRUT_PARTIAL $XA_CARDINAL 12
		send_get_property $windowid $XA_WM_TRANSIENT_FOR $XA_WINDOW 1
		send_get_property $windowid $XA_WM_NORMAL_HINTS $XA_WM_SIZE_HINTS 18
		send_get_property $windowid $XA_WM_HINTS $XA_WM_HINTS 9
		after_reply map_window $windowid
		send_change_window_events $windowid $client_events
	else
		map_window $windowid
	fi
}

log_window() {
	local -n window="window_$1"
	local k

	log '%s\n' "window $1"
	for k in ${!window[@]}; do
		log '  [%s] = %s\n' $k "${window[$k]}"
	done
}

max() {
	(( $1 > $2 )) && echo $1 && return
	echo $2
}

layout_desktop() {
	:
}

recalculate_workarea() {
	local left=0 right=0 top=0 bottom=0
	local x=0 y=0
	local width=${screen_0[width_pixels]}
	local height=${screen_0[height_pixels]}
	local root=${screen_0[root]}
	local sstrut strut

	for sstrut in "${struts[@]}"; do
		log 'Strut: %s\n' $sstrut
		strut=( $sstrut )
		left=$(max left strut[0])
		right=$(max right strut[1])
		top=$(max top strut[2])
		bottom=$(max bottom strut[3])
	done
	(( x += left ))
	(( y += top ))
	(( width -= left + right ))
	(( height -= top + bottom ))
	
	log 'Work Area: x=%d y=%d width=%d height=%d\n' $x $y $width $height

	screen_0[wa_x]=$x
	screen_0[wa_y]=$y
	screen_0[wa_width]=$width
	screen_0[wa_height]=$height

	send_change_property $root $X_PropModeReplace \
		$XA_NET_WORKAREA $XA_CARDINAL 32 4 \
		$x $y $width $height

	layout_desktop
}

map_window() {
	local windowid=$1
	local root=${screen_0[root]}
	local pos
	local -n window="window_$windowid"

	log_window $windowid

	if [[ ${window[$XA_NET_WM_STRUT_PARTIAL]} ]]; then
		struts[windowid]=${window[$XA_NET_WM_STRUT_PARTIAL]}
		window[desktop]=$(( 16#FFFF ))
		recalculate_workarea
	elif [[ ${window[$XA_NET_WM_WINDOW_TYPE]} ]] && 
		(( ${window[$XA_NET_WM_WINDOW_TYPE]} == XA_NET_WM_WINDOW_TYPE_NORMAL )); then
		pos=( $(add_window $windowid) )
		send_set_border_color $windowid $bashwm_active_border
		send_set_window_pos $windowid ${pos[@]}
	fi
	(( window[desktop] |= (1 << current_desktop) ))

	send_map_window $windowid
	send_change_property $root $X_PropModeAppend $XA_NET_CLIENT_LIST \
		$XA_WINDOW 32 1 $windowid
}

