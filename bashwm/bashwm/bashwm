spawn() {
	export DISPLAY=:$dsp
	/usr/bin/env --default-signal -C "$HOME" setsid -f "$@"
}

new_terminal() {
	spawn /usr/local/bin/terminal
}

new_browser() {
	spawn /usr/local/bin/browser
