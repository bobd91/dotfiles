handle_key_press() {
	local keycode keymask keycode_cmd keycmd mask cmd

	read8 keycode
	readpad 26
	read16 keymask
	readpad 2

	log '< Key press %s\n' $keycode

	keycode_cmd="${keycode_command_map[keycode]}" 
	[[ $keycode_cmd ]] || return 0

	IFS=',' read -ra keycmds <<< "$keycode_cmd"
	for keycmd in "${keycmds[@]}"; do
		mask="${keycmd%:*}"
		(( mask == keymask )) || continue
		cmd="${keycmd#*:}"
		$cmd
		break
	done
}

add_tile() {
	local desktopid=$1
	local windowid=$2

	local -n tiles="desktiles_$desktopid"

	tiles=( ${tiles[@]::1} $windowid ${tiles[@]:1} )
}

add_float() {
	local desktopid=$1
	local windowid=$2
	local -n floats="deskfloats_$desktopid"

	floats+=( $windowid )
}

layout_tiles() {
	local desktopid=$1
	local -n tiles=desktiles_$desktopid

	local num_tiles=${#tiles[@]}
	local x=${screen_0[wa_x]}
	local y=${screen_0[wa_y]}
	local width=${screen_0[wa_width]}
	local height=${screen_0[wa_height]}
	local window w h hdiff i

	log '\nLaying out %d tiles\n' $num_tiles

	case $num_tiles in
		0)	:
			;;
		1)	send_set_window_pos ${tiles[0]} \
				$x $y $width $height
			;;
		2)	w=$(( width / 2 ))
			send_set_window_pos ${tiles[0]} \
				$x $y $w $height
			send_set_window_pos ${tiles[1]} \
				$((x + w)) $y $((width - w)) $height
			;;
		*)      local -n window="window_${tiles[0]}"
			w=${window[width]}
			(( x+=w, width-=w ))
			h=$(( height / (num_tiles - 1) ))
			hdiff=$(( height - (h * (num_tiles - 1)) ))
			for (( i=1 ; i<num_tiles ; i++ )); do
				send_set_window_pos ${tiles[i]} \
					$x $y \
					$width $(( h + hdiff ))
				(( y += h + hdiff, hdiff = 0 ))
			done
			;;
	esac
}

after_reply() {
	local cmd="(${@@Q})"

	after_replies[sequence_number]+="${#cmd}${cmd}"
