read_setup_leader <&"$xfd"

if (( $setup_success != 1 )); then
	read_setup_failure <&"$xfd"

	printf 'Setup Failed '
	(( $setup_success == 2 )) && printf '(Auth) '
	printf ': %s\n' "$setup_failure_reason"
	exit $setup_success
fi

echo "extra_length = $extra_length"

read_setup_ok <&"$xfd"

echo "read_count = $read_count"

echo "release number = $release_number"
echo "max_request_length = $max_request_length"
echo "vendor_length = $vendor_length"
echo "vendor = $vendor"
echo "screens = $no_of_screens"
echo "formats = $no_of_formats"
echo "keycodes = $min_keycode .. $max_keycode"

echo "width_pixels = ${screens[0-width_pixels]}"
echo "height_pixels = ${screens[0-height_pixels]}"
echo "width_mm = ${screens[0-width_mm]}"
echo "height_mm = ${screens[0-height_mm]}"

echo "root = ${screens[0-root]}"

declare -a keysym_command_map=(
	[$XK_1]="$X_Mod4Mask:select_desktop 1,$((X_Mod4Mask|X_ShiftMask)):move_to_desktop 1"
	[$XK_2]="$X_Mod4Mask:select_desktop 1,$((X_Mod4Mask|X_ShiftMask)):move_to_desktop 1"
	[$XK_3]="$X_Mod4Mask:select_desktop 1,$((X_Mod4Mask|X_ShiftMask)):move_to_desktop 1"
	[$XK_4]="$X_Mod4Mask:select_desktop 1,$((X_Mod4Mask|X_ShiftMask)):move_to_desktop 1"
	[$XK_Return]="$X_Mod4Mask:new_terminal"
	[$XK_b]="$X_Mod4Mask:new_browser"
	[$XK_p]="$X_Mod4Mask:show_menu"
)

send_change_window_events >&"$xfd"
send_get_keyboard_mapping >&"$xfd"

event_loop >&"$xfd" <&"$xfd"

if [[ $error_code ]]; then
	printf 'Error code: %d\n' $error_code
	printf 'Error seq_no: %d\n' $error_seq_no
	printf 'Error data: %04x\n' $error_data
	printf 'Error op code: %d:%d\n' $error_major_op_code $error_minor_op_code
fi
