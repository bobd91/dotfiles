handle_client_message() {
	local format window atom 
	local value=0

	read8 format
	readpad 2
	read32 window
	read32 atom
	case $format in
		8) read8 value; readpad 19 ;;
		16) read16 value; readpad 18 ;;
		32) read32 value; readpad 16 ;;
		*) log 'Bad client message format %s\n' $format; readpad 20 ;;
	esac
	log 'ClientMessage %s %s %s %s\n' $format $window $atom $value
	(( atom == XA_NET_CURRENT_DESKTOP )) && select_desktop $value
}
event_handlers[X_ClientMessage]=handle_client_message

intern_atoms() {
	send_intern_atom UTF8_STRING
	send_intern_atom _NET_CURRENT_DESKTOP
	send_intern_atom _NET_NUMBER_OF_DESKTOPS
	send_intern_atom _NET_SUPPORTED
	send_intern_atom _NET_ACTIVE_WINDOW
