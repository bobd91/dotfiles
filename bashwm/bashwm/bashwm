print8() {
	local t=0
	(( $1 )) && printf -v t '%x' "$(( $1 & 16#FF ))"
	printf '%b' "\x$t"
}

print16() {
	local val=$1
	local l

	print8 "$(( val >> 8 ))"
	print8 $val
}

printpad() {
	local i
	for (( i=0 ; i<$1 ; i++ )); do
		print8 0
	done
}

printpadv() {
	printpad "$(( (4 - ($1%4))%4 ))"
}


printchars() {
	printf "$2"
}

printxchars() {
	local xchars=$2
	local xchar
	local i

	for (( i=0 ; i<$1 ; i++ )); do
		xchar=${xchars:$(( i * 2 )):2}
		printf '%b' "\x$xchar"
	done
}

		

read8() {
	local t

	(( read_count++ ))
	IFS= read -d '' -n 1 t
	if [[ -n $t ]]; then
		printf -v "$1" '%d' "'$t"
	else
		printf -v "$1" "0"
	fi
}

read16() {
	local b1 b2
	read8 b1
	read8 b2
	printf -v "$1" "$(( b2 + (b1 << 8) ))"
}

read32() {
	local b1 b2 b3 b4
	read8 b1
	read8 b2
	read8 b3
	read8 b4
	printf -v "$1" "$(( b4 + (b3 << 8) + (b2 << 16) + (b1 << 24) ))"
}

readchars() {
	local i c s

	for (( i=0 ; i<$1 ; i++ )); do
		(( read_count++ ))
		IFS= read -d '' -n 1 c
		if [[ -z $c ]]; then
			readpad $(( $1 - i - 1 ))
			break
		fi
		s="$s$c"
	done
	printf -v "$2" '%s' "$s"
}

readpad() {
	local pad i

	for (( i=0 ; i<$1 ; i++ )); do
		(( read_count++ ))
		IFS= read -d '' -n 1 pad
	done
}

readpadv() {
	readpad "$(( (4 - ($1%4))%4 ))"
}

findxauth() {
	local proto=256
	local addr="${HOSTNAME}"
	local display="${DISPLAY#*:}"
	local length

	while [[ $xauth_proto != $proto ||
			$xauth_addr != $addr ||
			$xauth_display != $display ]]; do
		read16 xauth_proto
		read16 length
		readchars $length xauth_addr
		read16 length
		readchars $length xauth_display
		read16 xauth_name_length 
		readchars $xauth_name_length xauth_name
		read16 xauth_data_length
		readchars $xauth_data_length xauth_data
	done
}


