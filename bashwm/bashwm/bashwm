select_desktop() {
	local desktop=$1
	local root=${screen_0[root]}

	[[ $current_desktop != $desktop ]] || return

	hide_desktop $current_desktop
	current_desktop=$desktop
	show_desktop $current_desktop

	send_change_property $root $X_PropModeReplace \
		$XA_NET_CURRENT_DESKTOP $XA_CARDINAL 32 1 $desktop
}

hide_desktop() {
	local desktopid=$1
	local -n tiles=desktiles_$desktopid
	local -n floats=deskfloats_$desktopid

	log '\nHide Desktop %s\n' $desktopid
	log 'Hiding %s tiles and %s floats\n' ${#tiles[@]} ${#floats[@]}
	local ids=( ${tiles[@]} ${floats[@]} )
	log 'Unmapping %s windows\n' ${#ids[@]}
	for id in ${ids[@]}; do
		local -n window=window_$id
		window[mapped]=0
		send_unmap_window $id
	done
	windowlist=()
	send_delete_property $root $XA_NET_CLIENT_LIST
}

show_desktop() {
	local desktopid=$1
	local -n tiles=desktiles_$desktopid
	local -n floats=deskfloats_$desktopid

	log '\nShow Desktop %s\n' $desktopid
	log 'Showing %s tiles and %s floats\n' ${#tiles[@]} ${#floats[@]}
	windowlist=( ${tiles[@]} ${floats[@]} )

	log 'Mapping %s windows\n' ${#windowlist[@]}
	for id in ${windowlist[@]}; do
		local -n window=window_$id
		window[mapped]=1
		send_map_window $id
	done
	
	if (( ${#windowlist[@]} )); then
		send_change_property $root $X_PropModeReplace \
			$XA_NET_CLIENT_LIST $XA_WINDOW 32 \
			${#windowlist[@]} ${windowlist[@]}
	else
		send_delete_property $root $XA_NET_CLIENT_LIST
	fi
}

