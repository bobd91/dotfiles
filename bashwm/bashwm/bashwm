calculate_workarea() {
	local left=0 right=0 top=0 bottom=0
	local x=0 y=0
	local width=${screen_0[width_pixels]}
	local height=${screen_0[height_pixels]}
	local root=${screen_0[root]}
	local sstrut strut

	for sstrut in "${struts[@]}"; do
		log 'Strut: %s\n' $sstrut
		strut=( $sstrut )
		left=$(max left strut[0])
		right=$(max right strut[1])
		top=$(max top strut[2])
		bottom=$(max bottom strut[3])
	done
	(( x += left ))
	(( y += top ))
	(( width -= left + right ))
	(( height -= top + bottom ))
	
	log 'Work Area: x=%d y=%d width=%d height=%d\n' $x $y $width $height

	screen_0[wa_x]=$x
	screen_0[wa_y]=$y
	screen_0[wa_width]=$width
	screen_0[wa_height]=$height

	send_change_property $root $X_PropModeReplace \
		$XA_NET_WORKAREA $XA_CARDINAL 32 4 \
		$x $y $width $height

	layout_tiles $current_desktop
}

map_window() {
	local windowid=$1
	local root=${screen_0[root]}
	local -n window="window_$windowid"

	(( ${window[mapped]} )) && return
	window[mapped]=1

	log '\ndesktiles_0=(%s)\n' "${desktiles_0[*]}"

	if [[ ${window[$XA_NET_WM_STRUT_PARTIAL]} ]]; then
		log '\nAdd strut %s\n' $windowid
		window[type]=strut
		struts[windowid]=${window[$XA_NET_WM_STRUT_PARTIAL]}
		calculate_workarea
	else
		window[desktop]=$current_desktop
		if [[ -z ${window[$XA_NET_WM_WINDOW_TYPE]} ]] || 
			(( ${window[$XA_NET_WM_WINDOW_TYPE]} \
				== XA_NET_WM_WINDOW_TYPE_NORMAL )); then
			log '\nAdd tile %s\n' $windowid
			window[type]=tile
			send_set_border_color $windowid $wm_active_border
			add_tile $current_desktop $windowid
			window[desktop]=$current_desktop
			layout_tiles $current_desktop
		else
			log '\nAdd float %s\n' $windowid
			window[type]=float
			add_float $current_desktop $windowid
			window[desktop]=$current_desktop
		fi
	fi

	log '\ndesktiles_0=(%s)\n' "${desktiles_0[*]}"

	windowlist+=( $windowid )

	log "\nWindowlist=(%s)\n" "${windowlist[*]}"

	send_map_window $windowid
	send_change_property $root $X_PropModeAppend $XA_NET_CLIENT_LIST \
		$XA_WINDOW 32 1 $windowid
}

remove_window() {
	local windowid=$1
	local -n window=window_$windowid
	local type=${window[type]}
	local windowids=desk${type}s_${window[desktop]}

	log "\nRemove window type %s id %s\n" $type $windowid

	unset 'window[desktop]'

	log "Var=%s\n" $windowids

	remove_id $windowids $windowid
}

remove_id() {
	local arr=$1
	local -n ids=$arr
	local id=$2
	local list=" ${ids[*]} "

	log "Removing %s from %s\n" $id "$arr"

	ids=( ${list/ $id / } )

	log '\nRemove <%s> from <%s> => (%s)\n' "$id" "$list" "${ids[*]}"
}

unmap_window() {
	local windowid=$1
	local -n window=window_$windowid
	local root=${screen_0[root]}
	local desktopid

	(( ${window[mapped]} )) || return

	log '\ndesktiles_0=(%s)\n' "${desktiles_0[*]}"

	window[mapped]=0
	case "${window[type]}" in
		strut)	unset 'struts[windowid]'
			calculate_workarea
			;;
		tile)	desktopid=${window[desktop]}
			remove_window $windowid
			layout_tiles $desktopid
			;;
		float)  remove_window $windowid
			;;
		*)	log '\nUnknown window type: %s\n' "${window[type]}"
			log_window $windowid
			;;
	esac

	log '\ndesktiles_0=(%s)\n' "${desktiles_0[*]}"

	log "\nWindowlist=(%s)\n" "${windowlist[*]}"
	remove_id windowlist $windowid
	log "\nWindowlist=(%s)\n" "${windowlist[*]}"

	if (( ${#windowlist[@]} )); then
		send_change_property $root $X_PropModeReplace \
			$XA_NET_CLIENT_LIST $XA_WINDOW 32 \
			${#windowlist[@]} ${windowlist[@]}
	else
		send_delete_property $root $XA_NET_CLIENT_LIST
	fi
}

handle_unmap_notify() {
	local windowid event
	local root=${screen_0[root]}

	readpad 3
	read32 event
	read32 windowid
	readpad 20

	log '< UnmapNotify for window %s from %s\n' $windowid $event

	(( event == root )) && return

	local -n window=window_$windowid
	(( window[mapped] )) && unmap_window $windowid
}


