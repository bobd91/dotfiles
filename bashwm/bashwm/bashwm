print_setup() {
	print8 $lsb_first
	printpad 1
	print16 $proto_major
	print16 $proto_minor
	print16 18
	print16 16
	printpad 2
	printchars 18 "MIT-MAGIC-COOKIE-1"
	printpadv 18
	printxchars 16 70ede6e7730126b60ef055cdcf07d541
	printpadv 16
}

read_setup_leader() {
