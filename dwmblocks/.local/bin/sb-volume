#!/bin/bash

# Prints the current volume or ¯¼ñ if muted.
spkr='¯İ©'
muted='¯¼ñ'

TERMINAL=${TERMINAL:-st}

vol_cmd="wpctl get-volume @DEFAULT_SINK@"
stat_cmd="wpctl status"

if [[ $BUTTON ]]; then
	case $BUTTON in
		1) pavucontrol -t 3; pkill -SIGRTMIN+10 "${STATUSBAR:-dwmblocks}" ;;
		2) wpctl set-mute @DEFAULT_SINK@ toggle ;;
		3) setsid -f "$TERMINAL" -e "$EDITOR" "$0" ;;
	esac
	exit
fi

print_volume() {
	local vol="$($vol_cmd)"
	local wpstat

	if [[ -z $vol || $vol =~ 'Volume: 1.00' ]]; then
		# may be actual 100% but ...
		# may be dummy output or no selected device (no '*') on startup
		# so check status for selected device that is not Dummy Output
		wpstat="$($stat_cmd | sed '/\*.*vol: 1.00/!'d)"
		while [[ -z "${wpstat// }" || $wpstat =~ 'Dummy Output' ]]; do
			vol=""
			sleep 0.1
			wpstat="$($stat_cmd | sed '/\*.*vol: 1.00/!'d)"
		done
		[[ $vol ]] || vol="$($vol_cmd)"
		printf 'wpstat=<%s>\n' "$wpstat" >> vol.log
		printf 'vol=<%s>\n' "$vol" >> vol.log
	fi

	[[ $vol =~ '[MUTED]' ]] && echo "$muted" && return
	vol="${vol#*Volume: }"
	hundreds="${vol%\.*}"
	vol="${vol#*\.}"
	(( $hundreds )) && vol="$hundreds$vol"

	echo "$spkr $vol%"

}

print_volume
